#!/usr/bin/env bash
# manage_my_process skriptini idarə edən init skripti

if [ $# -ne 1 ]; then
    echo "Usage: manage_my_process {start|stop|restart}"
    exit 1
fi

PID_FILE="/tmp/my_process.pid"

case "$1" in
    start)
        ./manage_my_process &
        echo $! > "$PID_FILE"
        echo "manage_my_process started"
        ;;
    stop)
        if [ -f "$PID_FILE" ]; then
            kill "$(cat "$PID_FILE")"
            rm "$PID_FILE"
            echo "manage_my_process stopped"
        fi
        ;;
    restart)
        # Əvvəl dayandırırıq
        if [ -f "$PID_FILE" ]; then
            kill "$(cat "$PID_FILE")"
            rm "$PID_FILE"
        fi
        # Sonra yenidən başladırıq
        ./manage_my_process &
        echo $! > "$PID_FILE"
        echo "manage_my_process restarted"
        ;;
    *)
        echo "Usage: manage_my_process {start|stop|restart}"
        exit 1
        ;;
esac
